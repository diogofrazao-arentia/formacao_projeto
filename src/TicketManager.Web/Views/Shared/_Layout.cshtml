<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Internal Ticket Manager</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="nav">
            <a class="brand" asp-controller="Tickets" asp-action="Index">Internal Ticket Manager</a>
            <a asp-controller="Tickets" asp-action="Index">Tickets</a>
            <a class="button button-secondary" asp-controller="Tickets" asp-action="Create">Novo ticket</a>
        </nav>
    </header>

    <main class="page">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
